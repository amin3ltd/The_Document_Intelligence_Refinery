# Document Intelligence Refinery Configuration
# Copy this file to .env and customize the values

# VLM Configuration
# Provider: lmstudio, ollama, openai, google
REFINERY_VLM_PROVIDER=lmstudio
REFINERY_VLM_MODEL=llava-1.6-mistral-7b
REFINERY_LM_STUDIO_URL=http://localhost:1234
REFINERY_OLLAMA_URL=http://localhost:11434

# OpenAI API (if using openai provider)
REFINERY_API_KEY=your-openai-api-key-here

# Extraction Settings
REFINERY_DEFAULT_STRATEGY=auto
REFINERY_MAX_COST_PER_DOC=10.0
REFINERY_MAX_PAGES_PER_DOC=100

# Logging
REFINERY_LOG_LEVEL=INFO
